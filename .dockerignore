# Version control / IDE
.git
.gitignore
.idea/
.playwright-mcp/

# Python
.venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
build/

# Secrets and local databases (never ship these in the image)
.env
*.db
instance/

# Node / frontend build artifacts (frontend is rebuilt inside the image)
node_modules/
frontend/node_modules/
frontend/dist/

# Tests and docs (not needed at runtime)
tests/
e2e/
docs/
# ...except the OpenAPI spec, which is served at runtime (/api/docs).
!docs/openapi.yaml
